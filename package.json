{
  "name": "chestflow",
  "version": "1.0.0",
  "description": "Controle Financeiro Offline",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5180 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "build": {
    "appId": "com.chestflow.app",
    "productName": "ChestFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "electron-preload.js",
      "src-tauri/icons/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src-tauri/target/release/chestflow-backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "icon": "src-tauri/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "chart.js": "^4.4.0",
    "flatpickr": "^4.6.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "axios": "^1.14.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  }
}
