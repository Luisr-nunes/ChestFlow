{
  "name": "chestflow",
  "version": "1.1.0",
  "description": "Controle Financeiro Offline",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5180 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.chestflow.app",
    "productName": "ChestFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/target/release/chestflow-backend.exe",
        "to": "backend.exe"
      }
    ],
    "win": {
      "icon": "assets/icons/icon.ico",
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  }
}
